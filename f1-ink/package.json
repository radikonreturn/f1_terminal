{
    "name": "f1-terminal-cli",
    "version": "1.0.0",
    "description": "Real-time F1 standings, schedule and race results in your terminal",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "f1-terminal-cli": "dist/index.js"
    },
    "files": [
        "dist/"
    ],
    "keywords": [
        "f1",
        "formula1",
        "terminal",
        "cli",
        "tui"
    ],
    "author": "radikonreturn",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/radikonreturn/f1_terminal"
    },
    "scripts": {
        "build": "esbuild src/index.jsx --bundle --platform=node --packages=external --format=esm --target=node18 --outfile=dist/index.js",
        "start": "node dist/index.js",
        "test": "echo \"No tests yet\" && exit 0",
        "run": "node dist/index.js",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "chalk": "^4.1.2",
        "ink": "^4.4.1",
        "ink-select-input": "^5.0.0",
        "ink-spinner": "^5.0.0",
        "ink-table": "^3.1.0",
        "ink-text-input": "^5.0.1",
        "node-fetch": "^3.3.2",
        "react": "^18.3.1"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-react": "^7.28.5",
        "@babel/register": "^7.28.6",
        "esbuild": "^0.27.3",
        "esbuild-register": "^3.6.0"
    }
}